# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mikrotik_controller
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_ECHO=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Security Configuration
SECURITY_SECRET_KEY=your_secret_key_at_least_32_characters_long_here
SECURITY_ALGORITHM=HS256
SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=30
SECURITY_REFRESH_TOKEN_EXPIRE_DAYS=7
SECURITY_PASSWORD_MIN_LENGTH=8
SECURITY_ENCRYPTION_KEY=your_encryption_key_at_least_32_characters_long_here

# Application Configuration
APP_NAME=MikroTik Controller
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# API Configuration
APP_API_PREFIX=/api/v1
APP_CORS_ORIGINS=["http://localhost:3000"]
APP_CORS_CREDENTIALS=true
APP_CORS_METHODS=["*"]
APP_CORS_HEADERS=["*"]

# Rate Limiting
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_PER_MINUTE=60

# Pagination
APP_DEFAULT_PAGE_SIZE=50
APP_MAX_PAGE_SIZE=100

# Worker Configuration (optional - defaults to Redis URL)
# APP_CELERY_BROKER_URL=redis://localhost:6379/0
# APP_CELERY_RESULT_BACKEND=redis://localhost:6379/0
APP_CELERY_TASK_TIME_LIMIT=300
APP_CELERY_TASK_SOFT_TIME_LIMIT=270

# Health Check
APP_HEALTH_CHECK_TIMEOUT=1
